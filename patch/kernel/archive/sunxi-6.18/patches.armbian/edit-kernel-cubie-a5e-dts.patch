From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: John Doe <john.doe@somewhere.on.planet>
Date: Sun, 11 Jan 2026 12:11:10 +0000
Subject: Patching kernel sunxi64 files
 arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts

Signed-off-by: John Doe <john.doe@somewhere.on.planet>
---
 arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts | 85 ++++++++++
 1 file changed, 85 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts b/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts
index 7f16223d723f..4c67eda14ddf 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a527-cubie-a5e.dts
@@ -74,10 +74,42 @@ reg_usb_vbus: vbus {
 		regulator-max-microvolt = <5000000>;
 		vin-supply = <&reg_vcc5v>;
 		gpio = <&r_pio 0 8 GPIO_ACTIVE_HIGH>;	/* PL8 */
 		enable-active-high;
 	};
+
+	reg_pcie_3v3: pcie-3v3 {
+		compatible = "regulator-fixed";
+		regulator-name = "pcie-3v3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-enable-ramp-delay = <1000>;
+		regulator-always-on;
+		regulator-boot-on;
+		gpio = <&r_pio 0 11 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+	};
+
+	gma340_oe: gma340-oe {
+		compatible = "regulator-fixed";
+		regulator-name = "gma340-oe";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+		regulator-boot-on;
+		gpio = <&pio 1 7 GPIO_ACTIVE_LOW>;
+	};
+
+	gma340_pcie: gma340-pcie {
+		compatible = "regulator-fixed";
+		regulator-name = "gma340-pcie";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+		regulator-boot-on;
+		gpio = <&pio 1 6 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+	};
 };
 
 &ehci0 {
 	status = "okay";
 };
@@ -174,10 +207,25 @@ &pio {
 	vcc-pg-supply = <&reg_bldo1>;
 	vcc-ph-supply = <&reg_cldo3>;	/* via VCC-IO */
 	vcc-pi-supply = <&reg_cldo3>;
 	vcc-pj-supply = <&reg_cldo4>;
 	vcc-pk-supply = <&reg_cldo1>;
+
+	spi0_pins: spi0-pins {
+		pins = "PC2","PC4", "PC12";
+		allwinner,pinmux = <4>;
+		function = "spi0";
+		drive-strength = <10>;
+	};
+
+	spi0_cs_pin: spi0-cs0-pin {
+		pins = "PC3";
+		allwinner,pinmux = <4>;
+		function = "spi0";
+		drive-strength = <10>;
+		bias-pull-up;   /* cs, hold, wp should be pulled up */
+	};
 };
 
 &r_i2c0 {
 	status = "okay";
 
@@ -419,5 +467,43 @@ &usb_otg {
 &usbphy {
 	usb0_vbus-supply = <&reg_vcc5v>;
 	usb1_vbus-supply = <&reg_usb_vbus>;
 	status = "okay";
 };
+
+&spi0 {
+    pinctrl-0 = <&spi0_pins>, <&spi0_cs_pin>;
+       pinctrl-names = "default"; 
+       status = "okay";
+       w25q128: flash@0 {
+           compatible = "winbond,w25q128fw", "jedec,spi-nor"; 
+           reg = <0>;
+           spi-max-frequency = <24000000>;
+           vcc-supply = <&reg_cldo1>;
+           status = "okay";
+       };
+};
+
+/* PCIE and USB Switch */
+&combophy { 
+    resets = <&ccu RST_BUS_PCIE_USB3>;
+    phy_use_sel = <0>; /* 0:PCIE; 1:USB3 */
+    status = "okay";
+};
+
+&pcie {
+    reset-gpios = <&pio 7 11 GPIO_ACTIVE_HIGH>;
+    wake-gpios = <&pio 7 12 GPIO_ACTIVE_HIGH>;
+    num-lanes  = <1>;
+    clk-freq-100M;
+    pcie3v3-supply = <&reg_pcie_3v3>;  
+    status = "okay";
+};
+
+&usbc1 {
+    device_type = "usbc1";
+    usb_regulator_io = "nocare";
+    usb_wakeup_suspend = <1>;
+    wakeup-source;
+    status = "okay";
+};
-- 
