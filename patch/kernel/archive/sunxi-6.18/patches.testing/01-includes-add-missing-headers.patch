+
+typedef void (*sunxi_dma_timeout_callback)(void *param);
+
+struct sunxi_dma_desc {
+	bool is_bmode;
+	bool is_timeout;
+	unsigned timeout_steps; /* the steps is the time for channel timer,the max is 511,1 step = 20.48us */
