--- /dev/null
+++ b/include/errcode/sunxi-err.h
@@ -0,0 +1,197 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/* Copyright(c) 2020 - 2023 Allwinner Technology Co.,Ltd. All rights reserved. */
+/*
+ * Allwinner's errcode
+ *
+ * Copyright (c) 2023, lvda <lvda@allwinnertech.com>
